# AI case summaries are OFF by default — the detection engine is fully
# deterministic and needs no AI. Set to "on" to enable a prose summary.
# WARNING: with GROQ_API_KEY (third party) this sends transaction data off-host.
# Use LLM_BASE_URL (a local model) to keep data on your infrastructure.
FMS_AI_SUMMARIES=off

# Only used when FMS_AI_SUMMARIES=on:
GROQ_API_KEY=
# Optional self-hosted LLM (e.g. Ollama: http://localhost:11434/v1) — keeps data on-host.
LLM_BASE_URL=
LLM_MODEL=llama-3.3-70b-versatile
LLM_API_KEY=

# Optional: lock down the API. If set, all /cases and /reports requests must
# send an "X-API-Key" header with this value. Leave blank for open (dev) mode.
FMS_API_KEY=

# Gmail alert settings
GMAIL_USER=your-gmail@gmail.com
GMAIL_APP_PASSWORD=xxxx-xxxx-xxxx-xxxx
ALERT_EMAIL=your-gmail@gmail.com

# Optional: webhook for flagged-case alerts (Slack incoming-webhook or any JSON endpoint)
ALERT_WEBHOOK_URL=
# Hours between automatic OFAC list refreshes (0 disables; default 24)
FMS_OFAC_REFRESH_HOURS=24
