# FMS demo / test environment — SAFE TO COMMIT. No real secrets here.
# Selected by test/run.ps1 / test/run.sh via FMS_ENV_FILE.

# Application store: a pre-seeded local SQLite database (test/fms_demo.db).
FMS_APP_DB_URL=
FMS_DB_PATH=test/fms_demo.db

# Ingestion/detection config for this environment (API-push mode, no bank DB).
FMS_BANK_CONFIG=test/bank_config.yaml

# Fixed token-signing secret so demo logins stay valid — DEMO ONLY, do not reuse.
FMS_AUTH_SECRET=demo-only-secret-not-for-production-do-not-reuse-000000

# Demo push-ingestion key (send transactions with header: X-API-Key: demo-ingest-key).
FMS_INGEST_API_KEY=demo-ingest-key

# AI summaries OFF (deterministic prose), email OFF — nothing leaves the host.
GROQ_API_KEY=
