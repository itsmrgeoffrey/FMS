# LLM key used for plain-English case summaries (Groq).
# The engine's risk scoring is fully deterministic and works without this;
# the key is only used to generate the human-readable summary text.
GROQ_API_KEY=gsk_your-groq-key-here

# Optional: self-hosted LLM instead of Groq. Point at any OpenAI-compatible
# endpoint (e.g. Ollama: http://localhost:11434/v1) so transaction data never
# leaves your infrastructure. LLM_API_KEY only if your endpoint requires one.
LLM_BASE_URL=
LLM_MODEL=llama-3.3-70b-versatile
LLM_API_KEY=

# Optional: lock down the API. If set, all /cases and /reports requests must
# send an "X-API-Key" header with this value. Leave blank for open (dev) mode.
FMS_API_KEY=

# Gmail alert settings
GMAIL_USER=your-gmail@gmail.com
GMAIL_APP_PASSWORD=xxxx-xxxx-xxxx-xxxx
ALERT_EMAIL=your-gmail@gmail.com
